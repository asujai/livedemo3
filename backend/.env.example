# ---- Tilo Translate backend configuration ----
# Copy this file to ".env" and fill in real values. NEVER commit ".env".

# Gemini API key (server-side only, never shipped to the mobile app)
GEMINI_API_KEY=your_key_here

# Port the backend listens on
PORT=8787

# CORS: comma separated list of allowed origins, or "*" for any (dev only)
CORS_ORIGIN=*

# ---- Optional token tuning (safe defaults if omitted) ----
# Total expiry of an ephemeral token (minutes)
TOKEN_EXPIRE_MINUTES=30
# Window in which a NEW Live session may be started with the token (minutes)
TOKEN_NEW_SESSION_MINUTES=2
# How many sessions a single token may initiate
TOKEN_USES=1
